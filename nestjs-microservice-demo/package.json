{
  "name": "nest-microservice",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "scripts": {
    "start:gateway": "cd api-gateway && npm run start:dev",
    "start:auth": "cd auth-service && npm run start:dev",
    "start:user": "cd user-service && npm run start:dev",
    "start:product": "cd product-service && npm run start:dev",
    "start:all": "concurrently -n gateway,auth,user,product -c green,blue,yellow,magenta \"npm run start:gateway\" \"npm run start:auth\" \"npm run start:user\" \"npm run start:product\""
  },
