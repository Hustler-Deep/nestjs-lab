{
  "name": "product-service",
  "version": "0.0.1",
  "description": "Product service for NestJS microservice architecture with product management, database integration, and TypeORM-based data operations.",
  "author": "Deep Akabari",
  "private": true,
  "license": "MIT",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && nest build",
    "format": "prettier --write .",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --fix .",
    "pre-commit": "npm run lint && npm run format && npm run build",
    "typeorm": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js",
    "migration:generate": "cross-env-shell \"npm run typeorm migration:generate -- -d src/config/typeorm.config.ts src/database/migrations/$npm_config_name\"",
    "migration:run": "cross-env-shell \"npm run typeorm migration:run -- -d src/config/typeorm.config.ts\"",
    "migration:revert": "cross-env-shell \"npm run typeorm migration:revert -- -d src/config/typeorm.config.ts\""
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "engineStrict": true,
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/shared-lib": "file:../shared-lib",
    "@nestjs/typeorm": "^11.0.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "typeorm": "^0.3.28"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "rimraf": "^6.1.3",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "keywords": [
    "nestjs",
    "product-service",
    "microservices",
    "typeorm",
    "postgresql",
    "database",
    "product-management",
    "typescript",
    "nodejs",
    "nestjs-typeorm",
    "backend",
    "rest-api",
    "class-validator",
    "class-transformer",
    "shared-library",
    "distributed-system",
    "rxjs",
    "migration",
    "orm"
  ]
}
