{
  "name": "auth-service",
  "version": "0.0.1",
  "description": "Authentication service for NestJS microservice architecture with JWT-based authentication, user validation, and secure credential management.",
  "author": "Deep Akabari",
  "private": true,
  "license": "MIT",
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm run clean && nest build",
    "format": "prettier --write .",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint --fix .",
    "pre-commit": "npm run lint && npm run format && npm run build"
  },
  "engines": {
    "node": ">=24.15.0"
  },
  "engineStrict": true,
  "dependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.19",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/microservices": "^11.1.19",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/shared-lib": "file:../shared-lib",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@swc/cli": "^0.8.1",
    "@swc/core": "^1.15.33",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
   "keywords": [
    "nestjs",
    "auth-service",
    "authentication",
    "authorization",
    "jwt",
    "bcrypt",
    "microservices",
    "typescript",
    "nodejs",
    "nestjs-microservices",
    "backend",
    "user-authentication",
    "security",
    "token-based-authentication",
    "class-validator",
    "class-transformer",
    "shared-library",
    "rest-api",
    "distributed-system",
    "rxjs"
  ]
}
